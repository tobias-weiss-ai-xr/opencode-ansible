#!/usr/bin/env bash
# Validate all Ansible content: lint + syntax check.
set -euo pipefail

echo "=== Running ansible-lint ==="
ansible-lint --version
ansible-lint . 2>&1 || echo "⚠️  ansible-lint found issues (non-fatal)"

echo ""
echo "=== Syntax check all playbooks ==="
for pb in playbooks/*.yml; do
  echo "  → ${pb}"
  ansible-playbook --syntax-check "$pb" -i inventory/hosts.yml 2>/dev/null || {
    echo "  ⚠️  Syntax error in ${pb} (may need inventory — try with --syntax-check only)"
  }
done

echo ""
echo "✅ Validation complete"
