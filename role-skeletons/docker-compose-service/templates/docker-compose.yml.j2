# {{ compose_project_name }} — Docker Compose (generated by Ansible)
# Override this template in your role's templates/ directory.
---
services:
  app:
    image: "{{ image_name | default('alpine:latest') }}"
    container_name: "{{ compose_project_name }}"
    restart: "{{ compose_restart_policy }}"
    ports:
      - "{{ host_port | default('8080') }}:{{ container_port | default('80') }}"
